# Copy to .env and fill in real values. NEVER commit the real .env.
PORT=5001

# MongoDB connection string. Fill in your own — do NOT commit a real one.
# Local:  mongodb://127.0.0.1:27017/restaurant_reservation
# Atlas:  mongodb+srv://<user>:<password>@<cluster>/restaurant_reservation
MONGODB_URI=<your-mongodb-connection-string>

# JWT signing secret — generate a long random value: `openssl rand -hex 32`.
JWT_SECRET=<generate-with-openssl-rand-hex-32>
JWT_EXPIRES_IN=1d

# Comma-separated list of allowed frontend origins for CORS.
CLIENT_ORIGIN=http://localhost:5173

# Seed script bootstrap (used by `npm run seed`). Admin is required; customer is
# optional. Use strong, unique passwords — these are placeholders, not real values.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=<set-a-strong-admin-password>
# Optional demo customer — omit both to skip seeding it.
SEED_CUSTOMER_EMAIL=customer@example.com
SEED_CUSTOMER_PASSWORD=<set-a-strong-customer-password>
