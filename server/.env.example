# Copy to .env and fill in real values. NEVER commit the real .env.
PORT=5001

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/restaurant_reservation
# Atlas:  mongodb+srv://<user>:<password>@<cluster>/restaurant_reservation
MONGODB_URI=mongodb://127.0.0.1:27017/restaurant_reservation

# JWT signing secret — use a long random string in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# Comma-separated list of allowed frontend origins for CORS.
CLIENT_ORIGIN=http://localhost:5173

# Seed script admin bootstrap (used by `npm run seed`).
SEED_ADMIN_EMAIL=admin@restaurant.test
SEED_ADMIN_PASSWORD=Admin@12345
